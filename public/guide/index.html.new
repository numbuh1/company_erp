    <!-- ══════════════════════════════════════════ -->
    <section id="getting-started">
        <h2><span class="num">1</span> Getting Started</h2>

        <img class="guide-img" src="/guide/images/01-login.png" alt="Login screen">

        <h3>Logging In</h3>
        <p>Navigate to the application URL and sign in with your <strong>email and password</strong>. All features require authentication — you will be redirected to the login page if you are not signed in.</p>

        <h3>Access Control</h3>
        <p>What you can see and do depends on the <strong>permissions assigned to your role</strong>. If you try to access a page you do not have permission for, you will see a <code>403 Forbidden</code> error.</p>

        <div class="callout info">
            <span class="callout-icon">ℹ️</span>
            <div>Contact your administrator to request additional access. Permissions are managed through the <a href="roles.html">Roles</a> module.</div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════ -->
    <section id="navigation">
        <h2><span class="num">2</span> Navigation</h2>

        <img class="guide-img" src="/guide/images/02-layout.png" alt="App layout">

        <h3>Top Bar</h3>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Element</th><th>Description</th></tr></thead>
                <tbody>
                    <tr><td><strong>Logo / App Name</strong></td><td>Click to go to the Dashboard</td></tr>
                    <tr><td><strong>Hamburger icon</strong></td><td>Mobile only — toggles the sidebar</td></tr>
                    <tr><td><strong>Dark Mode Toggle</strong></td><td>Sun/Moon icon — switches between light and dark theme (saved automatically)</td></tr>
                    <tr><td><strong>Bell Icon</strong></td><td>Notifications with unread count badge; click to preview the latest 5 unread</td></tr>
                    <tr><td><strong>Profile Menu</strong></td><td>Your name — dropdown with Profile settings and Log Out</td></tr>
                </tbody>
            </table>
        </div>

        <h3>Left Sidebar</h3>
        <p>On desktop the sidebar is always visible. On mobile it is hidden by default — tap the hamburger icon in the top-left to open it.</p>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Group</th><th>Links</th></tr></thead>
                <tbody>
                    <tr><td>—</td><td>Dashboard</td></tr>
                    <tr><td><strong>Work</strong></td><td>Attendance, Announcements, Projects, Tasks, Timesheet, Calendar</td></tr>
                    <tr><td><strong>People</strong></td><td>Teams, Users, Recruitment, Skills</td></tr>
                    <tr><td><strong>Requests</strong></td><td>Leave Requests, OT Requests</td></tr>
                    <tr><td><strong>Admin</strong></td><td>Roles, Settings</td></tr>
                </tbody>
            </table>
        </div>

        <div class="callout info">
            <span class="callout-icon">ℹ️</span>
            <div>Sidebar links are shown or hidden based on the permissions assigned to your role.</div>
        </div>
    </section>

    <div class="page-nav">
        <span class="spacer"></span>
        <a href="dashboard.html">Dashboard →</a>
    </div>

</main>

<script>
(function () {
    const page = location.pathname.split('/').pop() || 'index.html';
    document.querySelectorAll('#toc a').forEach(a => {
        if (a.getAttribute('href') === page) a.classList.add('active');
    });
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('#toc a');
    if (sections.length > 1) {
        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    navLinks.forEach(a => a.classList.remove('active'));
                    const a = document.querySelector(`#toc a[href="#${e.target.id}"]`);
                    if (a) a.classList.add('active');
                }
            });
        }, { rootMargin: '-20% 0px -70% 0px' });
        sections.forEach(s => obs.observe(s));
    }
})();
</script>

</body>
</html>
